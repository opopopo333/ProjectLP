<Page x:Class="ProjectLP.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthorPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
            <TextBlock Text="Мои публикации" FontSize="24" FontWeight="Bold"/>
            <Button Content="+ Опубликовать новую книгу" Click="BtnAddBook_Click" 
                Padding="10,5" Margin="20,0,0,0" Background="#27AE60" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="DgAuthorBooks" Grid.Row="1" Margin="0,20,0,0" 
              AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Читателей" Binding="{Binding ReadingLists.Count}" Width="*"/>
                <DataGridCheckBoxColumn Header="Заморожена" Binding="{Binding IsFrozen}" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Действия">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Редактировать" Click="BtnEditBook_Click" Margin="2"/>
                                <Button Content="Текст" Click="BtnEditText_Click" Margin="2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
