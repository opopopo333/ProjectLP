<Page x:Class="ProjectLP.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationPage">

    <Grid Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Логин:"/>
            <TextBox x:Name="TbLogin" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Email:"/>
            <TextBox x:Name="TbEmail" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PbPassword" Margin="0,5,0,10" Height="25"/>

            <TextBlock Text="Повторите пароль:"/>
            <PasswordBox x:Name="PbConfirm" Margin="0,5,0,20" Height="25"/>

            <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Height="35" Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
            <Button Content="Назад" Click="BtnBack_Click" Background="Transparent" BorderThickness="0" Foreground="Gray" Margin="0,10"/>
        </StackPanel>
    </Grid>
</Page>
