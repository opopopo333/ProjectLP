<Page x:Class="ProjectLP.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="300">
            <TextBlock Text="Авторизация" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин:"/>
            <TextBox x:Name="TbLogin" Margin="0,5,0,10"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PbPassword" Margin="0,5,0,20"/>

            <Button Content="Войти" Click="BtnLogin_Click" Height="30" Cursor="Hand"/>
            <Button Content="Регистрация" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="Blue" Click="BtnReg_Click"/>
        </StackPanel>
    </Grid>
</Page>
