<Page x:Class="ProjectLP.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookDetailsPage">

    <Grid Background="White">
        <ScrollViewer>
            <StackPanel Margin="20">
                <!-- Кнопка назад -->
                <Button Content="← Назад" HorizontalAlignment="Left" Click="BtnBack_Click" Margin="0,0,0,20"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Обложка -->
                    <Image Source="{Binding CoverPath}" Height="400" Stretch="Uniform" Grid.Column="0"/>

                    <!-- Краткая инфа -->
                    
                    
                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Users.DisplayName}" FontSize="20" FontStyle="Italic" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Рейтинг: " FontSize="12" VerticalAlignment="Center" FontWeight="Bold"/>
                            <!-- Сюда выведем среднее число (например, 4.5) -->
                            <TextBlock x:Name="TxtRatingValue" Text="0.0" FontSize="20" FontWeight="Bold" Foreground="#F1C40F" Margin="5,0,10,0"/>
                            <TextBlock x:Name="TxtReviewCount" Text="(0 отзывов)" FontSize="14" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <TextBlock Text="Жанры: " FontWeight="Bold"/>
                            
                            <!-- Для вывода списка жанров через запятую -->
                            <ItemsControl ItemsSource="{Binding Genres}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        

                        <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="14"/>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,20">
                            <Button Content="Читать книгу" Width="150" Height="40" Background="#27AE60" Foreground="White" Click="BtnRead_Click"/>
                            <Button Content="Добавить в список" Width="150" Height="40" Margin="10,0" Click="BtnAddToList_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Жалоба на книгу" Foreground="Red" Click="BtnComplaintBook_Click"/>
                            <Button Content="Жалоба на автора" Foreground="Red" Margin="10,0" Click="BtnComplaintAuthor_Click"/>
                            <!-- Кнопка заморозки книги -->
                            <Button x:Name="BtnFreezeBook" Content="Заморозить книгу" Click="BtnFreezeBook_Click" Visibility="Collapsed" Background="#E74C3C" Foreground="White" Padding="10,5" Margin="0,0,0,10"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,30"/>

                <!-- Секция отзывов -->
                <TextBlock Text="Отзывы читателей" FontSize="24" Margin="0,0,0,15"/>

                <!-- Форма добавления отзыва (скрыть, если аккаунт заморожен) -->
                <StackPanel x:Name="PanelAddReview" Margin="0,0,0,20">
                    <TextBox x:Name="TbReviewText" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Tag="Напишите ваш отзыв..."/>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Оценка (1-10): " VerticalAlignment="Center"/>
                        <Slider x:Name="SliderRating" Minimum="1" Maximum="10" Width="200" TickPlacement="BottomRight" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ElementName=SliderRating, Path=Value}" Margin="10,0" VerticalAlignment="Center"/>
                        <Button Content="Отправить" Width="100" Click="BtnSendReview_Click"/>
                    </StackPanel>
                </StackPanel>

                <ItemsControl x:Name="IcReviews">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,5" Padding="10" CornerRadius="5">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="{Binding Users.DisplayName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Rating, StringFormat='Оценка: {0}/10'}" HorizontalAlignment="Right" Foreground="OrangeRed"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,5"/>
                                    <Button Content="Пожаловаться" HorizontalAlignment="Left" FontSize="10" Click="BtnReportReview_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
