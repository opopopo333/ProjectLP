<Page x:Class="ProjectLP.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage" Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Контент -->
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <StackPanel Grid.Column="0" Background="#2C3E50">
            <!-- Профиль -->
            <Button x:Name="BtnProfile" Click="BtnProfile_Click" ToolTip="Профиль" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\user.png" Width="40"/>
            </Button>

            <!-- Каталог -->
            <Button x:Name="BtnCatalog" Click="BtnCatalog_Click" ToolTip="Каталог книг" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\catalog.png" Width="40"/>
            </Button>

            <!-- Списки -->
            <Button x:Name="BtnLists" Click="BtnLists_Click" ToolTip="Списки книг" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\lists.png" Width="40"/>
            </Button>

            <!-- Страница автора (Скрыта по умолчанию) -->
            <Button x:Name="BtnAuthor" Visibility="Collapsed" Click="BtnAuthor_Click" ToolTip="Мои книги" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\author.png" Width="40"/>
            </Button>

            <!-- Администрирование (Скрыта по умолчанию) -->
            <Button x:Name="BtnAdmin" Visibility="Collapsed"  Click="BtnAdmin_Click" ToolTip="Администрирование" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\admin.png" Width="40"/>
            </Button>

            <!-- Заморозка (Скрыта по умолчанию) -->
            <Button x:Name="BtnFrozen" Visibility="Collapsed" Background="Crimson" Click="BtnFrozen_Click" ToolTip="Аккаунт заморожен" Style="{StaticResource SidebarButtonStyle}">
                <Image Source="\Resources\Images\warning.png" Width="40"/>
            </Button>
        </StackPanel>

        <!-- ОБЛАСТЬ КОНТЕНТА -->
        <Frame x:Name="ActiveFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
