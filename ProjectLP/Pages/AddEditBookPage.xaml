<Page x:Class="ProjectLP.Pages.AddEditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectLP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditBookPage" Loaded="Page_Loaded">

    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30" MaxWidth="700" HorizontalAlignment="Left">
                <TextBlock Text="Управление книгой" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

                <TextBlock Text="Название книги" Margin="0,0,0,5" Foreground="Gray"/>
                <TextBox x:Name="TbTitle" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5,0"/>

                <TextBlock Text="Жанр" Margin="0,0,0,5" Foreground="Gray"/>
                <ComboBox x:Name="CbGenre" Height="35" Margin="0,0,0,15" DisplayMemberPath="Name" VerticalContentAlignment="Center"/>

                <TextBlock Text="Аннотация (описание)" Margin="0,0,0,5" Foreground="Gray"/>
                <TextBox x:Name="TbDescription" Height="80" Margin="0,0,0,15" TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>

                <TextBlock Text="Текст произведения" Margin="0,0,0,5" Foreground="Gray"/>
                <TextBox x:Name="TbContent" Height="250" Margin="0,0,0,20" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="5"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Сохранить" Click="BtnSave_Click" Width="160" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Отмена" Click="BtnCancel_Click" Width="100" Height="40" Margin="15,0,0,0" Background="#BDC3C7" Foreground="White" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
